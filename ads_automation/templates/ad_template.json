        "y": 400,
        "width": 900,
        "height": 600,
        "start_time": 2,
        "border_radius": 20,
        "shadow": {
          "blur": 20,
          "color": "#000000",
          "opacity": 0.3
        }
      },
      {
        "type": "video", 
